# Copy to .env on the deploy host (never commit .env).
# Generate token: openssl rand -hex 32

MCP_BEARER_TOKEN=replace-with-long-random-hex-secret

# Browser operator panel at https://mcp.bratek.io/panel/ (separate from MCP bearer; never exposed to JS)
MCP_PANEL_USER=operator
MCP_PANEL_PASSWORD=replace-with-strong-panel-password
# openssl rand -hex 32
MCP_PANEL_SESSION_SECRET=replace-with-random-hex-secret
# Set false only for local HTTP testing behind loopback compose.
MCP_PANEL_SESSION_HTTPS_ONLY=true
# Session cookie max-age in seconds (default 24h).
# MCP_PANEL_SESSION_MAX_AGE=86400
# Optional: append-only JSONL audit file inside a mounted volume
# MCP_PANEL_LOG_PATH=/var/log/mcp_panel/executions.jsonl

# Public base URL for tools/documentation (sample MCP echoes this for connectivity proof).
GATEWAY_PUBLIC_URL=https://mcp.bratek.io

# MCP Streamable HTTP allowlist primary hostname (must match public edge Host). Required for production.
MCP_PUBLIC_HOST=mcp.bratek.io

# Extra Host / Origin allowlist entries (comma-separated, lowercase). Use for apex redirects,
# alternate public names, and/or explicit Docker mesh names, e.g.:
#   sample_mcp,schedulelab_mcp,controltower_mcp,schedule_analysis_mcp,controltower_orchestrator_mcp
# If unset, default mesh service names are still merged via MCP_INTERNAL_MESH_HOSTS defaults in code.
MCP_EXTRA_ALLOWED_HOSTS=

# Override default in-compose MCP hostnames for DNS-rebinding allowlists (comma-separated).
# Default when unset: sample_mcp, schedulelab_mcp, controltower_mcp, schedule_analysis_mcp, controltower_orchestrator_mcp
# MCP_INTERNAL_MESH_HOSTS=sample_mcp,schedulelab_mcp,controltower_mcp,schedule_analysis_mcp,controltower_orchestrator_mcp

# Optional: override TLS directory mount for nginx (defaults to ./tls in compose).
# Production: TLS_VOLUME_MOUNT=/etc/letsencrypt/live/mcp.bratek.io
TLS_VOLUME_MOUNT=./tls

# On-VM verification against loopback bind (see docker-compose publish). For public-URL checks without editing this file:
# MCP_VERIFY_BASE_URL=https://mcp.bratek.io bash ops/scripts/verify_mcp_gateway.sh
VERIFY_BASE_URL=https://127.0.0.1:18443

# Optional: pin Docker Compose project name on shared hosts
COMPOSE_PROJECT_NAME=mcp_gateway

# When host nginx already uses :80 / :443, bind the gateway to loopback only, then reverse-proxy:
# MCP_GATEWAY_HTTP_PUBLISH=127.0.0.1:18080:80
# MCP_GATEWAY_HTTPS_PUBLISH=127.0.0.1:18443:443

# Read-only mounts for production MCP services (VM host paths).
# ScheduleLab published root on prod VM (see ScheduleLab openclaw USER.md).
SCHEDULELAB_PUBLISHED_HOST_PATH=/app/schedulelab_data/published
# Control Tower runtime state (see ControlTower infra production env example).
CONTROLTOWER_RUNTIME_HOST_PATH=/srv/controltower/shared/.controltower_runtime

# Optional: operator panel in-compose MCP URLs (defaults match docker-compose.yml).
# INTERNAL_MCP_SCHEDULE_ANALYSIS_URL=http://schedule_analysis_mcp:8080/mcp/
# INTERNAL_MCP_CONTROLTOWER_ORCHESTRATOR_URL=http://controltower_orchestrator_mcp:8080/mcp/
