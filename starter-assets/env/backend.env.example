# Copy to infra/env/backend.env (gitignored) and adjust values.
# Container DNS hostname for Postgres is the Compose service name.

ACTION_DESK_ENV=production
ACTION_DESK_DATABASE_URL=postgresql+psycopg://action_desk:CHANGE_ME@actiondesk-postgres:5432/action_desk
# Same-origin production: leave empty. For local split dev (e.g. Next on :3000, API on :8000), use:
# ACTION_DESK_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
ACTION_DESK_CORS_ORIGINS=
# Public browser URL (OpenAPI / docs); must match nginx TLS host.
ACTION_DESK_PUBLIC_BASE_URL=https://actiondesk.bratek.io
