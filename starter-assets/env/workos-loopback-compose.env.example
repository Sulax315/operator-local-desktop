# Copy this file to deploy/env.production before running docker-compose.

# Canonical production runtime for workos.bratek.io behind host nginx.
# The compose file also enforces the bind ports and container names below.
PYTHONPATH=/app
WORK_OS_API_HOST=0.0.0.0
WORK_OS_API_PORT=8001
WORK_OS_FRONTEND_HOST=0.0.0.0
WORK_OS_FRONTEND_PORT=3001
WORK_OS_STORAGE_PATH=/data/work_os.sqlite3
WORK_OS_STORAGE_MOUNT_PATH=/data
WORK_OS_REQUIRE_STORAGE_MOUNT=true
WORK_OS_BACKUP_DIR=/backups
WORK_OS_LOG_LEVEL=INFO
WORK_OS_PUBLIC_BASE_URL=https://workos.bratek.io

# Frontend-to-backend container routing behind host nginx
WORK_OS_API_BASE_URL=http://backend:8001
WORK_OS_API_BASE_PATH=/api

# Outlook / Microsoft Graph
OUTLOOK_CLIENT_ID=<azure-app-client-id>
OUTLOOK_TENANT_ID=<azure-tenant-id-or-common>
OUTLOOK_REDIRECT_URI=https://workos.bratek.io/api/auth/outlook/callback
# Optional only if your Azure app registration requires a confidential client.
OUTLOOK_CLIENT_SECRET=<optional-client-secret>
