# Phase 1 — copy to `.env` and replace secrets before `docker compose up`.
# Paths below are container-internal unless noted.

# ---------------------------------------------------------------------------
# Timezone (all services)
# ---------------------------------------------------------------------------
TZ=UTC

# ---------------------------------------------------------------------------
# Postgres (container `postgres` — not published to host)
# Creates default cluster + databases from ./docker/postgres/init on first run.
# ---------------------------------------------------------------------------
POSTGRES_USER=bratek_ops
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=postgres

# ---------------------------------------------------------------------------
# Metabase application database (same Postgres service, database `metabase`)
# ---------------------------------------------------------------------------
MB_DB_TYPE=postgres
MB_DB_DBNAME=metabase
MB_DB_PORT=5432
MB_DB_USER=bratek_ops
MB_DB_PASS=change-me-strong-password
MB_DB_HOST=postgres

# ---------------------------------------------------------------------------
# n8n — editor / public URL (browser hits loopback published port 8083)
# ---------------------------------------------------------------------------
N8N_HOST=127.0.0.1
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://127.0.0.1:8083/

# ---------------------------------------------------------------------------
# n8n — Postgres persistence (database `n8n`, created by init script)
# Use the same credentials as POSTGRES_* unless you create dedicated roles.
# ---------------------------------------------------------------------------
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=bratek_ops
DB_POSTGRESDB_PASSWORD=change-me-strong-password

# ---------------------------------------------------------------------------
# Volumes (Docker named volumes — see docker-compose.yml)
# - postgres_data  → /var/lib/postgresql/data
# - n8n_data         → /home/node/.n8n (local encryption keys, cache)
# ---------------------------------------------------------------------------
